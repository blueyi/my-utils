*.log
*.pyc
common/*.pyc
common/.ropeproject

# Generated by create_links.sh (machine-specific paths)
config/my-utils.env

# Cursor session / user data (keep settings.json, mcp.json, rules/)
cursor_bak/User/History/
cursor_bak/User/globalStorage/
cursor_bak/User/workspaceStorage/
# Cursor projects: ephemeral per-workspace data (keep mcps/ for MCP config)
cursor_bak/projects/*/terminals/
cursor_bak/projects/*/agent-transcripts/
cursor_bak/projects/*/agent-tools/
cursor_bak/projects/*/worker.log
cursor_bak/projects/*/.workspace-trusted
# macOS temp workspace dirs (var-folders-*), not meaningful to version
cursor_bak/projects/var-folders-*/

# Binary files and tools
bin/
*.o
*.a
*.so
*.dylib

# Build artifacts
build/
dist/
*.egg-info/
__pycache__/

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak
.env.local
