  function! s:MaybeCocInstall()
    if filereadable(expand('~/.vimbak/coc-extensions-done'))
      return
    endif
    call timer_start(2000, function('s:DoCocInstall'))
  endfunction
  function! s:DoCocInstall(_)
    if filereadable(expand('~/.vimbak/coc-extensions-done'))
      return
    endif
    if !exists(':CocInstall')
      return
    endif
    call writefile([], expand('~/.vimbak/coc-extensions-done'))
    silent! execute 'CocInstall coc-json coc-clangd coc-pyright coc-rust-analyzer'
  endfunction
endif

