"-- For java development setting --
func! Run_java()
    exe ":ccl"
    exe ":update"
    exe ':!javac %'
    if v:shell_error == 0
        exe ":!java -cp . %<"
    endif
endfunc

"-- For CUDA development setting --
func! Run_cuda()
    exe ":ccl"
    exe ":update"
    let cuda_inc = expand('~') . '/cuda/samples/common/inc'
    if !isdirectory(cuda_inc)
        let cuda_inc = '/usr/local/cuda/samples/common/inc'
    endif
    exe ':!nvcc --ptxas-options=-v % -I "' . cuda_inc . '" -o %<.o'
    if v:shell_error == 0
        exe ":!./%<.o"
    endif
endfunc

"-- For python development setting --
func! Run_py()
    exe ":ccl"
    exe ":update"
    exe ":!python3 %"
endfunc

"-- For shell development setting --
func! Run_sh()
    exe ":ccl"
    exe ":update"
    exe ":!bash %"
endfunc


