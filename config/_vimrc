" File: _vimrc
" Description: Vim/Neovim config for Linux + macOS. vim-plug, coc.nvim, ALE, fzf, etc.
" Run :PlugInstall to install plugins. Coc requires Vim 9.0.0438+ or Neovim 0.8.0+ and Node.js.
" =============================================================================
"        << Linux + macOS | Vim + Neovim >>
" =============================================================================
let g:is_macos = has('macunix')
let g:is_linux = !g:is_macos
let g:islinux = g:is_linux
let g:iswindows = 0
let g:is_neovim = has('nvim')
let g:isGUI = has("gui_running")

" Linux Gvim/Vim default
if g:is_linux
    if g:isGUI
        if filereadable("/etc/vim/gvimrc.local")
            source /etc/vim/gvimrc.local
        endif
    else
        if filereadable("/etc/debian_version")
            runtime! debian.vim
        endif
        if filereadable("/etc/vim/vimrc.local")
            source /etc/vim/vimrc.local
        endif
    endif
endif


" =============================================================================
"  Plugins (vim-plug)
" =============================================================================
if empty(glob('~/.vim/autoload/plug.vim'))
    silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
      \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
    autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif
" coc.nvim requires Vim 9.0.0438+ or Neovim 0.8.0+
let g:coc_available = (v:version >= 900 && has('patch-9.0.0438')) || (has('nvim') && has('nvim-0.8'))

call plug#begin('~/.vim/plugged')

Plug 'junegunn/vim-plug'
Plug 'junegunn/goyo.vim', { 'for': 'markdown' }
Plug 'junegunn/limelight.vim', { 'for': 'markdown' }
if g:coc_available
  Plug 'neoclide/coc.nvim', {'branch': 'release'}
endif
Plug 'dense-analysis/ale'
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'
Plug 'ludovicchabant/vim-gutentags'
Plug 'rust-lang/rust.vim'
Plug 'bling/vim-airline'
Plug 'jiangmiao/auto-pairs'
Plug 'honza/vim-snippets'
Plug 'tpope/vim-fugitive'
Plug 'majutsushi/tagbar'
Plug 'godlygeek/tabular'
Plug 'plasticboy/vim-markdown'
Plug 'scrooloose/nerdcommenter'
Plug 'scrooloose/nerdtree', { 'on': 'NERDTreeToggle' }
Plug 'mbbill/undotree'
Plug 'tpope/vim-surround'
Plug 'tpope/vim-sleuth'
Plug 'blueyi/a.vim'
Plug 'Yggdroot/indentLine'
Plug 'blueyi/vim-template'
Plug 'tomasr/molokai'
Plug 'flazz/vim-colorschemes'

call plug#end()

