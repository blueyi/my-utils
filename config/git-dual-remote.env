# Git dual-remote defaults (GitHub primary + GitCode mirror).
# Override in ~/.my-utils.env (not committed).
#
# Enable the git() wrapper and fallback pull/push in interactive shells.
export GIT_DUAL_REMOTE_ENABLED="${GIT_DUAL_REMOTE_ENABLED:-1}"

# GitHub / GitCode namespace — only repos under this owner get dual-remote mirrors.
# Third-party repos (e.g. github.com/pyenv/pyenv) are left unchanged.
export GIT_DUAL_REMOTE_GITHUB_USER="${GIT_DUAL_REMOTE_GITHUB_USER:-blueyi}"
export GIT_DUAL_REMOTE_GITCODE_USER="${GIT_DUAL_REMOTE_GITCODE_USER:-blueyi}"

# Seconds before treating a remote op as timed out (SSH connect + op).
export GIT_DUAL_REMOTE_TIMEOUT="${GIT_DUAL_REMOTE_TIMEOUT:-20}"

# Name of the GitCode fallback remote (fetch/pull when GitHub is unreachable).
export GIT_DUAL_REMOTE_FALLBACK_REMOTE="${GIT_DUAL_REMOTE_FALLBACK_REMOTE:-gitcode}"

# Set to 1 to print fallback messages to stderr.
export GIT_DUAL_REMOTE_VERBOSE="${GIT_DUAL_REMOTE_VERBOSE:-1}"
