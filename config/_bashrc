# ~/.bashrc — interactive → shell_init.bash; non-interactive → ~/.env.rc only (see resetrc SECTION: env.rc)

if [ -z "${MY_UTILS_ENV_RC_LOADED:-}" ] && [ -f "$HOME/.env.rc" ]; then
  . "$HOME/.env.rc"
  export MY_UTILS_ENV_RC_LOADED=1
fi

case $- in
  *i*) ;;
  *) return;;
esac
source ~/.shell_init.bash
